# ==============================================================
# AI Resume Screener — Environment Variables Template
# Copy this to backend/.env and fill in your real values
# NEVER commit backend/.env to Git!
# ==============================================================

# ── Gemini AI API Key ──────────────────────────────────────────
# 1. Go to: https://aistudio.google.com/apikey
# 2. Sign in with your Google account
# 3. Click "Create API Key"
# 4. Copy the key here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Flask Secret Key ───────────────────────────────────────────
# Any random long string. Used for session encryption.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=airesume-secret-key-change-this-in-production

# ── Flask Environment ──────────────────────────────────────────
# Use "development" locally, "production" on server
FLASK_ENV=development

# ── Email / SMTP (Gmail) ───────────────────────────────────────
# 1. Go to: https://myaccount.google.com/apppasswords
# 2. Sign in → Select app: "Mail" → device: "Other (Custom name)"
# 3. Generate App Password (16 char code, NOT your regular Gmail password)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_16_char_app_password
MAIL_SENDER=youremail@gmail.com

# ── Database (MySQL — Railway/Render) ─────────────────────────
# Leave blank to use local SQLite (recommended for local dev)
# Format: mysql+pymysql://user:password@host:port/dbname
MYSQL_PUBLIC_URL=
MYSQLHOST=
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=resume_screener
MYSQLPORT=3306

# ── Google OAuth (Optional) ───────────────────────────────────
# 1. Go to: https://console.cloud.google.com/
# 2. Create project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add redirect URI: http://localhost:5000
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
